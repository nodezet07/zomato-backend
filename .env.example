# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://127.0.0.1:27017/food-app

# Redis
REDIS_URL=redis://127.0.0.1:6379
FIREBASE_ENABLED=false
# Recommended: base64 of the full Firebase service account JSON
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
# Alternative (if not using base64 JSON):
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
ENABLE_BULLMQ=true
SOCKET_REDIS_ADAPTER=true
CACHE_TTL_SECONDS=300
LIVE_LOCATION_TTL_SECONDS=7200

# Phase 18 — security
CORS_ORIGINS=http://localhost:8081,http://localhost:5000,http://localhost:5174,http://192.168.1.101:5174
TRUST_PROXY=false
JSON_BODY_LIMIT=2mb
RATE_LIMIT_API_WINDOW_MS=900000
RATE_LIMIT_API_MAX=200
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_PAYMENT_MAX=30

# URLs
FRONTEND_URL=http://localhost:8081
MASTER_URL=http://localhost:5000

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ADMIN_ACCESS_SECRET=change-me-admin-access-secret
JWT_ADMIN_REFRESH_SECRET=change-me-admin-refresh-secret

# Email (optional for now)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM=noreply@example.com

# AWS S3 (optional for now)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=

# API docs
API_URL=http://localhost:5000

# Razorpay (Phase 9 — test keys from dashboard)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
